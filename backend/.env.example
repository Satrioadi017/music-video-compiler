# Application
APP_NAME=AI Social Media Automation
DEBUG=false
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/social_automation
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/social_automation

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# AWS S3 (optional, for media storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=social-media-automation
AWS_REGION=us-east-1

# Instagram API
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# YouTube API
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# TikTok API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Facebook API
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Twitter/X API
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# RTMP Streaming
RTMP_SERVER_URL=rtmp://localhost:1935/live
STREAM_DEFAULT_RESOLUTION=1920x1080
STREAM_DEFAULT_BITRATE=4500k
STREAM_DEFAULT_FPS=30
